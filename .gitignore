# =============================================================================
# finance-copilot — .gitignore
# =============================================================================

# ----- Python ----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
*.whl
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
coverage.xml
*.log

# ----- Virtual environments --------------------------------------------------
.venv/
venv/
env/
ENV/
.env.local
.env.development
.env.production

# ----- Secrets (NEVER commit) ------------------------------------------------
.env
*.pem
*.key
*.p12
*.pfx
secrets/

# ----- Data (large / auto-generated) ----------------------------------------
data/raw/
data/cache/
data/processed/
# keep the gitkeep stubs
!data/raw/.gitkeep
!data/cache/.gitkeep
!data/processed/.gitkeep

# ----- Node / Frontend -------------------------------------------------------
node_modules/
.next/
.nuxt/
frontend/dist/
frontend/.env.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo

# ----- Docker ----------------------------------------------------------------
.docker/
docker-compose.override.yml

# ----- IDE / OS --------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ----- Jupyter ---------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# ----- Misc ------------------------------------------------------------------
tmp/
scratch/
