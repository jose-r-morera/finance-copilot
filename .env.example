# =============================================================================
# finance-copilot — .env.example
# Copy this file to .env and fill in real values.
# .env is NEVER committed to git.
# =============================================================================

# --- Application -------------------------------------------------------------
APP_ENV=development               # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR

# --- LLM Providers (use the one(s) you have access to) ----------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o               # default model for agents
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...                # Gemini
PRIMARY_LLM_PROVIDER=openai       # openai | anthropic | google

# --- Financial Data APIs -----------------------------------------------------
# Alpha Vantage — free tier available: https://www.alphavantage.co/
ALPHA_VANTAGE_API_KEY=...

# Financial Modeling Prep — https://financialmodelingprep.com/
FMP_API_KEY=...

# SEC EDGAR — no key needed, but set a compliant User-Agent header
SEC_EDGAR_USER_AGENT="finance-copilot contact@example.com"

# --- Observability -----------------------------------------------------------
# Langfuse (tracing, prompt versioning etc) — https://langfuse.com/
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Redis (cache / task queue) ----------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Database (PostgreSQL) ---------------------------------------------------
POSTGRES_HOST=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=finance_copilot
POSTGRES_PORT=5432
# DATABASE_URL is constructed automatically if omitted.
# DATABASE_URL=postgresql://postgres:postgres@db:5432/finance_copilot

# --- Storage -----------------------------------------------------------------
DATA_DIR=./data                   # local data root — override for cloud storage paths
